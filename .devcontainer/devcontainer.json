    "image": "mcr.microsoft.com/devcontainers/python:3.14",
    "postCreateCommand": "pip install -r requirements.txt --no-deps",
    "forwardPorts": [8000],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.black-formatter"
            ]
        }
    }
}