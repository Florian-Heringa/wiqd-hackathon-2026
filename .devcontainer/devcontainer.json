{
    "name": "Python with Poetry",
    "image": "mcr.microsoft.com/devcontainers/python:latest",
    "postCreateCommand": [
        "curl -sSL https://install.python-poetry.org | python3 -",
        "export PATH=\"$HOME/.local/bin:$PATH\"",
        "poetry install"
    ],
    "forwardPorts": [8000],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.black-formatter"
            ]
        }
    }
}