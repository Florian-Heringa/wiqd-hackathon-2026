{
    "name": "Python with Poetry",
    "image": "mcr.microsoft.com/devcontainers/python:latest",
    "features": {
        "ghcr.io/devcontainers/features/poetry:1": {}
    },
    "postCreateCommand": "poetry install",
    "forwardPorts": [8000],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.black-formatter"
            ]
        }
    }
}